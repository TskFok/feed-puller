# Docker：与 aria2 相同的 UID/GID（注入 compose environment，并作为容器运行用户）
# 设为 0 在 macOS Docker 上通常仍无法写宿主机挂载目录，应使用 aria2 实际写文件的 uid
PUID=1000
PGID=1000

# 仅当 aria2 返回的路径前缀与容器内挂载路径不一致时填写（已同路径映射可留空）
# DOWNLOAD_PATH_HOST_PREFIX=/Users/你的用户名/Downloads
# DOWNLOAD_PATH_CONTAINER_PREFIX=/data/downloads

PORT=8080
BASE_URL=http://localhost:8080
MYSQL_DSN=feed_puller:feed_puller@tcp(127.0.0.1:3306)/feed_puller?parseTime=true&loc=UTC
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
SESSION_SECRET=please-change-this-session-secret-at-least-32-chars
ARIA2_RPC_URL=http://127.0.0.1:6800/jsonrpc
ARIA2_RPC_SECRET=
# 用于 aria2 hook 回调鉴权；留空将禁用 hook 端点（POST /api/downloads/aria2-hook）
# 设置后，aria2-hook.sh 通过 Authorization: Bearer <secret> 调用此项目实时上报下载完成
ARIA2_HOOK_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 设为 false 禁用账号密码登录（需配置飞书登录并完成账号绑定）
PASSWORD_LOGIN_ENABLED=true
STATIC_DIR=web/dist

